<?xml version="1.0" encoding="utf-8"?>
<MetaCli>
  <ParameterList>
    <Parameter Id="param-new-workspace-path" ValueShapeId="shape-path">
      <Description>Empty target directory for the MetaMesh workspace.</Description>
      <IsRequired>true</IsRequired>
      <Name>path</Name>
    </Parameter>
    <Parameter Id="param-new-workspace-name" ValueShapeId="shape-text">
      <Description>Optional mesh display name.</Description>
      <Name>name</Name>
    </Parameter>
    <Parameter Id="param-scan-root" ValueShapeId="shape-path">
      <Description>Folder to scan for meta workspaces.</Description>
      <IsRequired>true</IsRequired>
      <Name>root</Name>
    </Parameter>
    <Parameter Id="param-scan-new-workspace" ValueShapeId="shape-path">
      <Description>Empty target directory for the generated MetaMesh workspace.</Description>
      <IsRequired>true</IsRequired>
      <Name>new-workspace</Name>
    </Parameter>
    <Parameter Id="param-scan-name" ValueShapeId="shape-text">
      <Description>Optional mesh display name.</Description>
      <Name>name</Name>
    </Parameter>
    <Parameter Id="param-suggest-root" ValueShapeId="shape-path">
      <Description>Folder to scan for suggestions.</Description>
      <IsRequired>true</IsRequired>
      <Name>root</Name>
    </Parameter>
    <Parameter Id="param-show-workspace" ValueShapeId="shape-path">
      <Description>MetaMesh workspace. Defaults to the current directory.</Description>
      <Name>workspace</Name>
    </Parameter>
    <Parameter Id="param-check-workspace" ValueShapeId="shape-path">
      <Description>MetaMesh workspace. Defaults to the current directory.</Description>
      <Name>workspace</Name>
    </Parameter>
    <Parameter Id="param-impact-workspace" ValueShapeId="shape-path">
      <Description>MetaMesh workspace. Defaults to the current directory.</Description>
      <Name>workspace</Name>
    </Parameter>
    <Parameter Id="param-impact-handle" ValueShapeId="shape-text">
      <Description>Logical workspace handle to start from.</Description>
      <IsRequired>true</IsRequired>
      <Name>handle</Name>
    </Parameter>
    <Parameter Id="param-mount-workspace" ValueShapeId="shape-path">
      <Description>MetaMesh workspace. Defaults to the current directory.</Description>
      <Name>workspace</Name>
    </Parameter>
    <Parameter Id="param-mount-handle" ValueShapeId="shape-text">
      <Description>Logical workspace handle.</Description>
      <IsRequired>true</IsRequired>
      <Name>handle</Name>
    </Parameter>
    <Parameter Id="param-mount-path" ValueShapeId="shape-path">
      <Description>Physical workspace path to mount.</Description>
      <IsRequired>true</IsRequired>
      <Name>path</Name>
    </Parameter>
    <Parameter Id="param-link-workspace" ValueShapeId="shape-path">
      <Description>MetaMesh workspace. Defaults to the current directory.</Description>
      <Name>workspace</Name>
    </Parameter>
    <Parameter Id="param-link-from" ValueShapeId="shape-text">
      <Description>Source workspace handle.</Description>
      <IsRequired>true</IsRequired>
      <Name>from</Name>
    </Parameter>
    <Parameter Id="param-link-to" ValueShapeId="shape-text">
      <Description>Target workspace handle.</Description>
      <IsRequired>true</IsRequired>
      <Name>to</Name>
    </Parameter>
    <Parameter Id="param-link-kind" ValueShapeId="shape-text">
      <Description>Link kind.</Description>
      <IsRequired>true</IsRequired>
      <Name>kind</Name>
    </Parameter>
  </ParameterList>
</MetaCli>
