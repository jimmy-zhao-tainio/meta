<?xml version="1.0" encoding="utf-8"?>
<Model name="MetaCli">
  <EntityList>
    <Entity name="Application">
      <PropertyList>
        <Property name="Name" />
        <Property name="ExecutableName" isRequired="false" />
        <Property name="Version" isRequired="false" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
    </Entity>
    <Entity name="Command">
      <PropertyList>
        <Property name="Name" />
        <Property name="Token" isRequired="false" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="Application" />
        <Relationship entity="Command" role="ParentCommand" isRequired="false" />
      </RelationshipList>
    </Entity>
    <Entity name="ExecutableCommand">
      <RelationshipList>
        <Relationship entity="Command" />
      </RelationshipList>
    </Entity>
    <Entity name="ApplicationDefaultCommand">
      <RelationshipList>
        <Relationship entity="Application" />
        <Relationship entity="ExecutableCommand" />
      </RelationshipList>
    </Entity>
    <Entity name="ValueArity">
      <PropertyList>
        <Property name="Name" />
        <Property name="MinValueCount" />
        <Property name="MaxValueCount" isRequired="false" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
    </Entity>
    <Entity name="ValueShape">
      <PropertyList>
        <Property name="Name" />
        <Property name="ValueLabel" isRequired="false" />
        <Property name="AllowsOptionLikeValue" isRequired="false" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="ValueArity" />
      </RelationshipList>
    </Entity>
    <Entity name="AllowedValue">
      <PropertyList>
        <Property name="Value" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="ValueShape" />
        <Relationship entity="AllowedValue" role="PreviousValue" isRequired="false" />
      </RelationshipList>
    </Entity>
    <Entity name="Parameter">
      <PropertyList>
        <Property name="Name" />
        <Property name="Description" isRequired="false" />
        <Property name="IsRequired" isRequired="false" />
        <Property name="IsRepeatable" isRequired="false" />
        <Property name="DefaultValue" isRequired="false" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="ExecutableCommand" />
        <Relationship entity="ValueShape" />
      </RelationshipList>
    </Entity>
    <Entity name="Option">
      <RelationshipList>
        <Relationship entity="Parameter" />
      </RelationshipList>
    </Entity>
    <Entity name="OptionToken">
      <PropertyList>
        <Property name="Token" />
        <Property name="IsPrimary" isRequired="false" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="Option" />
        <Relationship entity="OptionToken" role="PreviousToken" isRequired="false" />
      </RelationshipList>
    </Entity>
    <Entity name="ParameterGroup">
      <PropertyList>
        <Property name="Name" />
        <Property name="Description" isRequired="false" />
        <Property name="IsRequired" isRequired="false" />
        <Property name="AllowsMultiple" isRequired="false" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="ExecutableCommand" />
      </RelationshipList>
    </Entity>
    <Entity name="ParameterGroupMember">
      <RelationshipList>
        <Relationship entity="ParameterGroup" />
        <Relationship entity="Parameter" />
        <Relationship entity="ParameterGroupMember" role="PreviousMember" isRequired="false" />
      </RelationshipList>
    </Entity>
    <Entity name="PositionalArgument">
      <RelationshipList>
        <Relationship entity="Parameter" />
        <Relationship entity="PositionalArgument" role="PreviousArgument" isRequired="false" />
      </RelationshipList>
    </Entity>
    <Entity name="ParserPolicy">
      <PropertyList>
        <Property name="Name" />
        <Property name="StopParsingToken" isRequired="false" />
        <Property name="AllowsEqualsValueSyntax" isRequired="false" />
        <Property name="AllowsOptionsAfterPositionals" isRequired="false" />
        <Property name="AllowsShortOptionClusters" isRequired="false" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="Application" />
        <Relationship entity="DuplicateOptionBehavior" isRequired="false" />
        <Relationship entity="UnknownTokenBehavior" isRequired="false" />
      </RelationshipList>
    </Entity>
    <Entity name="DuplicateOptionBehavior">
      <PropertyList>
        <Property name="Name" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
    </Entity>
    <Entity name="UnknownTokenBehavior">
      <PropertyList>
        <Property name="Name" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
    </Entity>
    <Entity name="Output">
      <PropertyList>
        <Property name="Name" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="ExecutableCommand" />
        <Relationship entity="OutputFormat" isRequired="false" />
        <Relationship entity="OutputStream" isRequired="false" />
      </RelationshipList>
    </Entity>
    <Entity name="OutputFormat">
      <PropertyList>
        <Property name="Name" />
        <Property name="ContentType" isRequired="false" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
    </Entity>
    <Entity name="OutputStream">
      <PropertyList>
        <Property name="Name" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
    </Entity>
    <Entity name="ExitCode">
      <PropertyList>
        <Property name="Code" />
        <Property name="Name" />
        <Property name="Description" isRequired="false" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="Application" />
        <Relationship entity="ExecutableCommand" isRequired="false" />
      </RelationshipList>
    </Entity>
  </EntityList>
</Model>
