    <Command Id="cmd-add-option-token" ApplicationId="app-meta-cli">
      <Description>Add an additional token for an option.</Description>
      <Name>add-option-token</Name>
      <Token>add-option-token</Token>
    </Command>
    <Command Id="cmd-add-positional" ApplicationId="app-meta-cli">
      <Description>Add a positional argument.</Description>
      <Name>add-positional</Name>
      <Token>add-positional</Token>
    </Command>
    <Command Id="cmd-add-parameter-group" ApplicationId="app-meta-cli">
      <Description>Start a parameter choice group.</Description>
      <Name>add-parameter-group</Name>
      <Token>add-parameter-group</Token>
    </Command>
    <Command Id="cmd-add-parameter-group-member" ApplicationId="app-meta-cli">
      <Description>Add another parameter to a group.</Description>
      <Name>add-parameter-group-member</Name>
      <Token>add-parameter-group-member</Token>
    </Command>
