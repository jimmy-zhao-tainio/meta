<?xml version="1.0" encoding="utf-8"?>
<SampleSourceCatalog>
  <MappingList>
    <Mapping Id="mapping:string-to-int">
      <Name>StringToInt</Name>
      <SourceTypeId>type:string</SourceTypeId>
      <TargetTypeId>type:int</TargetTypeId>
    </Mapping>
    <Mapping Id="mapping:int-to-decimal">
      <Name>IntToDecimal</Name>
      <SourceTypeId>type:int</SourceTypeId>
      <TargetTypeId>type:decimal</TargetTypeId>
    </Mapping>
    <Mapping Id="mapping:string-to-decimal:again">
      <Name>StringToDecimalAgain</Name>
      <SourceTypeId>type:string</SourceTypeId>
      <TargetTypeId>type:decimal</TargetTypeId>
    </Mapping>
  </MappingList>
</SampleSourceCatalog>
