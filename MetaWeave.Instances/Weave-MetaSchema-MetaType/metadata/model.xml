<?xml version="1.0" encoding="utf-8"?>
<Model name="MetaWeave">
  <EntityList>
    <Entity name="ModelRef">
      <PropertyList>
        <Property name="Alias" />
        <Property name="ModelName" />
        <Property name="WorkspacePath" />
      </PropertyList>
    </Entity>
    <Entity name="PropertyBinding">
      <PropertyList>
        <Property name="Name" />
        <Property name="SourceEntity" />
        <Property name="SourceProperty" />
        <Property name="TargetEntity" />
        <Property name="TargetProperty" />
      </PropertyList>
      <RelationshipList>
        <Relationship entity="ModelRef" role="SourceModel" />
        <Relationship entity="ModelRef" role="TargetModel" />
      </RelationshipList>
    </Entity>
  </EntityList>
</Model>